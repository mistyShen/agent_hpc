<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, #edf2f7 100%);
      color: #102a43;
    }
    .page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 32px 24px 48px;
    }
    .hero {
      background: #102a43;
      color: #f7fafc;
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 20px 50px rgba(16, 42, 67, 0.18);
    }
    .hero h1 {
      margin: 0 0 12px;
      font-size: 2rem;
    }
    .hero p {
      margin: 0;
      max-width: 72ch;
      line-height: 1.6;
      color: #d9e2ec;
    }
    .meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin: 24px 0;
    }
    .card {
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid #d9e2ec;
      border-radius: 20px;
      padding: 20px;
      box-shadow: 0 12px 30px rgba(16, 42, 67, 0.06);
    }
    .card h2, .card h3 {
      margin-top: 0;
    }
    .section-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 18px;
    }
    ul {
      margin: 0;
      padding-left: 20px;
      line-height: 1.6;
    }
    .pill {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      background: #d9e2ec;
      color: #102a43;
      font-size: 0.85rem;
      margin-right: 6px;
      margin-bottom: 6px;
    }
    .muted {
      color: #627d98;
    }
    code {
      background: #f1f5f9;
      padding: 2px 6px;
      border-radius: 6px;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="hero">
      <h1>{{ title }}</h1>
      <p>This report summarizes the single-cell workbench run, including data shape, schema decisions, QC, annotation, statistics, dependency skips, and generated artifacts.</p>
      <p class="muted">Generated at {{ generated_at }}</p>
    </div>

    <div class="meta">
      <div class="card">
        <h3>Dataset</h3>
        <p><strong>{{ data.kind }}</strong></p>
        <p>{{ data.n_obs }} cells</p>
        <p>{{ data.n_vars }} features</p>
      </div>
      <div class="card">
        <h3>Structure</h3>
        <p>{{ data.obs_columns|length }} obs columns</p>
        <p>{{ data.var_columns|length }} var columns</p>
        <p>{{ data.layers|length }} layers</p>
      </div>
      <div class="card">
        <h3>Artifacts</h3>
        <p>{{ artifacts|length }} tracked paths</p>
        <p>{{ dependency_skips|length }} dependency skips</p>
      </div>
      {% if data.modalities %}
      <div class="card">
        <h3>Modalities</h3>
        {% for name, modality in data.modalities.items() %}
        <span class="pill">{{ name }}: {{ modality.n_obs }} x {{ modality.n_vars }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>

    <div class="section-grid">
      <div class="card">
        <h2>Schema</h2>
        <ul>
          {% for item in schema.decisions %}
          <li><code>{{ item.key }}</code>: {{ item.value }}</li>
          {% endfor %}
          {% if schema.raw.issues %}
          {% for issue in schema.raw.issues %}
          <li>{{ issue.location }} ({{ issue.severity }}): {{ issue.message }}. Suggestion: {{ issue.suggestion }}</li>
          {% endfor %}
          {% endif %}
          {% if schema.raw.applied_fixes %}
          {% for fix in schema.raw.applied_fixes %}
          <li>Fix applied: {{ fix }}</li>
          {% endfor %}
          {% endif %}
        </ul>
      </div>

      <div class="card">
        <h2>QC</h2>
        <ul>
          {% for item in qc.decisions %}
          <li><code>{{ item.key }}</code>: {{ item.value }}</li>
          {% endfor %}
          {% if qc.raw.metrics %}
          {% for key, value in qc.raw.metrics.items() %}
          <li>Metric <code>{{ key }}</code>: {{ value }}</li>
          {% endfor %}
          {% endif %}
          {% if qc.raw.tools %}
          {% for key, value in qc.raw.tools.items() %}
          <li>Tool <code>{{ key }}</code>: {{ value }}</li>
          {% endfor %}
          {% endif %}
        </ul>
      </div>

      <div class="card">
        <h2>Annotation</h2>
        <ul>
          {% for item in annotation.decisions %}
          <li><code>{{ item.key }}</code>: {{ item.value }}</li>
          {% endfor %}
        </ul>
      </div>

      <div class="card">
        <h2>Statistics</h2>
        <ul>
          {% for item in stats.decisions %}
          <li><code>{{ item.key }}</code>: {{ item.value }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="section-grid" style="margin-top: 18px;">
      <div class="card">
        <h2>Dependency Skips</h2>
        <ul>
          {% for item in dependency_skips %}
          <li>{{ item.dependency }}: {{ item.reason }}</li>
          {% endfor %}
          {% if dependency_skips|length == 0 %}
          <li>No dependency skips were recorded.</li>
          {% endif %}
        </ul>
      </div>

      <div class="card">
        <h2>Artifacts</h2>
        <ul>
          {% for item in artifacts %}
          <li><code>{{ item.key }}</code>: {{ item.value }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</body>
</html>
